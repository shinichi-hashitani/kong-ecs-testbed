# =====================================================================
# kong-ecs-testbed - environment variables (template)
# Copy this file to .env and fill in real values. .env is gitignored.
# Load with:  set -a; source .env; set +a
# =====================================================================

# ---- AWS ----
# Named profile registered via `aws configure --profile kong-testbed`.
# Stores Access Key / Secret in ~/.aws/credentials. Do NOT put the secret here.
AWS_PROFILE=kong-testbed
AWS_REGION=ap-northeast-1
# Used for tagging / resource ARNs. Filled after `aws sts get-caller-identity`.
AWS_ACCOUNT_ID=

# ---- Kong Konnect (filled in Step 2) ----
# Personal Access Token (starts with `kpat_...`). Treat as a secret.
KONNECT_PAT=
# Konnect API server (Geo). US = https://us.api.konghq.com
KONNECT_SERVER_URL=https://us.api.konghq.com
# Control Plane name to create
KONNECT_CP_NAME=kong-ecs-testbed-cp

# ---- Kong Gateway DP (used in Step 5; passed to Terraform) ----
TF_VAR_kong_dp_image=kong/kong-gateway:3.8
TF_VAR_kong_dp_desired_count=1

# ---- httpbin (used in Step 4; passed to Terraform) ----
TF_VAR_httpbin_image=kennethreitz/httpbin:latest
TF_VAR_httpbin_desired_count=1

# ---- Naming / Tagging ----
PROJECT=kong-ecs-testbed
ENVIRONMENT=dev
